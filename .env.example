# Copy to .env.local and fill in.

# A funded Monad testnet private key — this is the oracle "verifier" that
# signs attestations. Get testnet MON at https://faucet.monad.xyz
RELAYER_PRIVATE_KEY=0xyourprivatekey

# Set automatically by `npm run deploy`. The deployed AttestationRegistry address.
NEXT_PUBLIC_CONTRACT_ADDRESS=
